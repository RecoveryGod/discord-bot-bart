# Discord bot token (Application → Bot → Token)
BOT_TOKEN=

# ID of the channel where payment notifications are sent
PAYMENT_CHANNEL_ID=

# ID of the role to mention when an Amazon gift card is detected
AMAZON_ROLE_ID=

# ID of the channel whose threads are considered "tickets" to monitor
TICKET_CHANNEL_ID=

# OpenAI API key for AI support feature
OPENAI_API_KEY=

# Optional: role ID to exclude from AI auto-replies (staff/support role)
STAFF_ROLE_ID=

# Optional: user ID of the ticket bot (tickets.bot) — enables auto-reply to custom ticket inquiries
TICKET_BOT_ID=

# Required for /price slash command: bot application ID (Discord Developer Portal → General Information)
CLIENT_ID=

# Optional: guild (server) ID for instant slash command registration (recommended)
GUILD_ID=

# Optional: Channel ID for per-ticket analytics cards (leave empty to disable)
# ANALYTICS_CHANNEL_ID=

# Optional: Hours of inactivity before warning the user (default: 48)
# AUTO_CLOSE_HOURS=48

# Optional: Channel ID where staff can use !rule / !rules / !rule-del commands.
# Rules added here apply globally as system-prompt instructions to the AI.
# TRAINING_CHANNEL_ID=

# Optional: Pre-build docs embedding index on bot startup (default: false → lazy on first query)
# DOCS_EMBED_ON_BOOT=false

# Optional: Debounce window for batching rapid-fire user messages (ms, default: 3000)
# BATCH_WAIT_MS=3000

# Optional: Hard ceiling on batch wait time (ms, default: 15000)
# BATCH_MAX_WAIT_MS=15000
